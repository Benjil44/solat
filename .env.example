# Copy this file to .env and fill in your values
# IMPORTANT: Change JWT_SECRET and ADMIN_KEY before going online!

# Port for the web server
PORT=3000

# Stream key — must match what the DJ uses
STREAM_KEY=djlive

# Secret for JWT tokens — CHANGE THIS to a long random string before going online
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-string

# Admin password — used to access /dj.html and /admin panel
# CHANGE THIS before going online — do not use "admin123" in production
ADMIN_KEY=change-this-to-your-admin-password

# Path to ffmpeg binary (full path on Windows)
FFMPEG_PATH=ffmpeg

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Set if your frontend is served from a different origin. Leave blank otherwise.
ALLOWED_ORIGIN=

# ── Stripe Payments (optional) ────────────────────────────────────────────────
# Leave blank to disable. Server starts fine without these.
# Keys: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Webhook secret: https://dashboard.stripe.com/webhooks
# Local testing: stripe listen --forward-to localhost:3000/payment/webhook
STRIPE_WEBHOOK_SECRET=
# Price ID of your membership plan (e.g. price_1ABC...)
STRIPE_PRICE_ID=
# Days of access one payment grants (default: 30)
STRIPE_ACCESS_DAYS=30
